]);

// Step 64: Verify document collection counts
db.feedback.countDocuments();


// -----------------------------------------------------------------------------
// Task 2: CRUD Operations
// -----------------------------------------------------------------------------

// Step 65: READ - Find all feedback documents where rating is 5
db.feedback.find({ rating: 5 });

// Step 66: READ - Find feedback for CS101 matching 'challenging' array element value
db.feedback.find({ course_code: 'CS101', tags: 'challenging' });

// Step 67: READ - Isolate projection metrics (Exclude _id constraint)
db.feedback.find({}, { student_id: 1, course_code: 1, rating: 1, _id: 0 });

// Step 68: UPDATE - Inject evaluation metadata field for low scores ($rating < 3)
db.feedback.updateMany({ rating: { $lt: 3 } }, { $set: { needs_review: true } });

// Step 69: UPDATE - Append status tag to elements requiring evaluation
db.feedback.updateMany({ needs_review: true }, { $push: { tags: 'reviewed' } });

// Step 70: DELETE - Purge legacy timeline blocks
db.feedback.deleteMany({ semester: '2021-EVEN' });


// -----------------------------------------------------------------------------
// Task 3: Aggregation Pipeline
// -----------------------------------------------------------------------------

// Step 71 & 72: Execution metrics collection pipeline with rounding transformations
db.feedback.aggregate([
  // Stage 1: Filter to target semester matching scope
  { $match: { semester: '2022-ODD' } },
  
  // Stage 2: Consolidate records by course code metrics
  {
    $group: {
      _id: '$course_code',
      avg_rating: { $avg: '$rating' },
      total_feedback: { $sum: 1 }
    }
  },
  
  // Stage 3: Order metrics sequentially by calculation results
  { $sort: { avg_rating: -1 } },
  
  // Step 72 - Stage 4: Map presentation field aliases and compute precision values
  {
    $project: {
      _id: 0,
      course_code: '$_id',
      total_feedback: 1,
      average_rating: { $round: ['$avg_rating', 1] }
    }
  }
]);

// Step 73: Deconstruct arrays to compile frequency metrics
db.feedback.aggregate([
  // Stage 1: Flatten structural array components
  { $unwind: '$tags' },
  
  // Stage 2: Calculate sum metrics per element
  {
    $group: {
      _id: '$tags',
      count: { $sum: 1 }
    }
  },
  
  // Stage 3: Sort by count frequency descending
  { $sort: { count: -1 } }
]);

// Step 74: Generate performance indexes and evaluate plan efficiency patterns
db.feedback.createIndex({ course_code: 1 });

// Execution plan diagnostic evaluation verification command
db.feedback.find({ course_code: 'CS101' }).explain('executionStats');
