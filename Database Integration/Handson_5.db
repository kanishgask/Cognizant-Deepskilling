// -----------------------------------------------------------------------------
// Task 1: Create the Collection and Insert Documents
// -----------------------------------------------------------------------------

// Step 60 & 61: Switch to/create the database and prepare collection context
use college_nosql;

// Step 62 & 63: Populate the collection with diverse sample data records
